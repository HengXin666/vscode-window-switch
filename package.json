{
  "name": "window-deck",
  "displayName": "Window Deck",
  "description": "Semantic navigation for multiple VS Code windows without changing their contents.",
  "version": "0.6.2",
  "publisher": "HengXin666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HengXin666/vscode-window-switch.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "window",
    "switcher",
    "workspace",
    "remote",
    "navigation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:windowDeck.installWorkbenchPatch",
    "onCommand:windowDeck.uninstallWorkbenchPatch",
    "onCommand:windowDeck.openPanel",
    "onCommand:windowDeck.showWindows",
    "onCommand:windowDeck.renameCurrentWindow",
    "onCommand:windowDeck.setCurrentWindowColor",
    "onCommand:windowDeck.cleanupStaleWindows",
    "onCommand:windowDeck.diagnoseFocusSupport",
    "onCommand:windowDeck.checkForUpdates",
    "onCommand:windowDeck.reloadAllWindows"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "windowDeck.installWorkbenchPatch",
        "title": "Window Deck: 安装顶部栏补丁",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.uninstallWorkbenchPatch",
        "title": "Window Deck: 卸载顶部栏补丁",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.openPanel",
        "title": "Window Deck: 打开高级管理面板",
        "category": "Window Deck",
        "icon": "$(window)"
      },
      {
        "command": "windowDeck.showWindows",
        "title": "Window Deck: 显示窗口列表",
        "category": "Window Deck",
        "icon": "$(window)"
      },
      {
        "command": "windowDeck.renameCurrentWindow",
        "title": "Window Deck: 重命名当前窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.setCurrentWindowColor",
        "title": "Window Deck: 设置当前窗口颜色",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.configureCurrentWindow",
        "title": "Window Deck: 配置当前窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.cleanupStaleWindows",
        "title": "Window Deck: 清理失联窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.diagnoseFocusSupport",
        "title": "Window Deck: 诊断聚焦支持",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.checkForUpdates",
        "title": "Window Deck: 检查更新",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.reloadAllWindows",
        "title": "Window Deck: 重载所有窗口",
        "category": "Window Deck"
      }
    ],
    "configuration": {
      "title": "Window Deck",
      "properties": {
        "windowDeck.heartbeatIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "当前 VS Code 窗口刷新到本机 Window Deck 注册表的心跳间隔。"
        },
        "windowDeck.staleAfterMs": {
          "type": "number",
          "default": 20000,
          "minimum": 5000,
          "description": "窗口超过这个时间没有发送心跳后，会显示为失联。"
        },
        "windowDeck.removeStaleAfterMs": {
          "type": "number",
          "default": 86400000,
          "minimum": 60000,
          "description": "清理命令会删除超过这个时间的失联窗口。"
        },
        "windowDeck.autoCheckUpdates": {
          "type": "boolean",
          "default": true,
          "description": "每 24 小时自动检查一次 GitHub Release，有新版本时提示下载并安装。"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "windowDeck.openPanel",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "windowDeck.installWorkbenchPatch"
        },
        {
          "command": "windowDeck.uninstallWorkbenchPatch"
        },
        {
          "command": "windowDeck.openPanel"
        },
        {
          "command": "windowDeck.showWindows"
        },
        {
          "command": "windowDeck.renameCurrentWindow"
        },
        {
          "command": "windowDeck.setCurrentWindowColor"
        },
        {
          "command": "windowDeck.configureCurrentWindow"
        },
        {
          "command": "windowDeck.cleanupStaleWindows"
        },
        {
          "command": "windowDeck.diagnoseFocusSupport"
        },
        {
          "command": "windowDeck.checkForUpdates"
        },
        {
          "command": "windowDeck.reloadAllWindows"
        }
      ]
    }
  },
  "scripts": {
    "compile": "rm -rf dist && tsc -p ./ && mkdir -p dist/vendor && cp ../vscode-extension-github-updater/dist/index.js dist/vendor/githubUpdater.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "check": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  }
}
