{
  "name": "window-deck",
  "displayName": "Window Deck",
  "description": "Semantic navigation for multiple VS Code windows without changing their contents.",
  "version": "0.3.2",
  "publisher": "HengXin666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HengXin666/vscode-window-switch.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "window",
    "switcher",
    "workspace",
    "remote",
    "navigation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:windowDeck.openPanel",
    "onCommand:windowDeck.showWindows",
    "onCommand:windowDeck.renameCurrentWindow",
    "onCommand:windowDeck.setCurrentWindowColor",
    "onCommand:windowDeck.cleanupStaleWindows",
    "onCommand:windowDeck.diagnoseFocusSupport"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "windowDeck.openPanel",
        "title": "Window Deck: 打开高级管理面板",
        "category": "Window Deck",
        "icon": "$(window)"
      },
      {
        "command": "windowDeck.showWindows",
        "title": "Window Deck: 显示窗口列表",
        "category": "Window Deck",
        "icon": "$(window)"
      },
      {
        "command": "windowDeck.renameCurrentWindow",
        "title": "Window Deck: 重命名当前窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.setCurrentWindowColor",
        "title": "Window Deck: 设置当前窗口颜色",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.configureCurrentWindow",
        "title": "Window Deck: 配置当前窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.applyCurrentWindowTitle",
        "title": "Window Deck: 应用窗口标题标记",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.cleanupStaleWindows",
        "title": "Window Deck: 清理失联窗口",
        "category": "Window Deck"
      },
      {
        "command": "windowDeck.diagnoseFocusSupport",
        "title": "Window Deck: 诊断聚焦支持",
        "category": "Window Deck"
      }
    ],
    "configuration": {
      "title": "Window Deck",
      "properties": {
        "windowDeck.heartbeatIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "当前 VS Code 窗口刷新到本机 Window Deck 注册表的心跳间隔。"
        },
        "windowDeck.staleAfterMs": {
          "type": "number",
          "default": 20000,
          "minimum": 5000,
          "description": "窗口超过这个时间没有发送心跳后，会显示为失联。"
        },
        "windowDeck.removeStaleAfterMs": {
          "type": "number",
          "default": 86400000,
          "minimum": 60000,
          "description": "清理命令会删除超过这个时间的失联窗口。"
        },
        "windowDeck.titleTokenMode": {
          "type": "string",
          "enum": [
            "disabled"
          ],
          "default": "disabled",
          "description": "预留给未来的单窗口标题标记支持。当前禁用，因为 VS Code 公开的是共享 window.title 配置。"
        },
        "windowDeck.applyWorkbenchColors": {
          "type": "boolean",
          "default": false,
          "description": "启用后，设置窗口颜色时也会写入当前 workspace 的 workbench.colorCustomizations。"
        },
        "windowDeck.autoApplyTitleMarkerOnKdeWayland": {
          "type": "boolean",
          "default": true,
          "description": "在 KDE Wayland 下自动写入当前 workspace 的 window.title 标记，让 KWin 更可靠地聚焦窗口。"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "windowDeck.showWindows",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "windowDeck.openPanel"
        },
        {
          "command": "windowDeck.showWindows"
        },
        {
          "command": "windowDeck.renameCurrentWindow"
        },
        {
          "command": "windowDeck.setCurrentWindowColor"
        },
        {
          "command": "windowDeck.configureCurrentWindow"
        },
        {
          "command": "windowDeck.applyCurrentWindowTitle"
        },
        {
          "command": "windowDeck.cleanupStaleWindows"
        },
        {
          "command": "windowDeck.diagnoseFocusSupport"
        }
      ]
    }
  },
  "scripts": {
    "compile": "rm -rf dist && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "check": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  }
}
